# Copy this file to ".env" (same folder) and fill in the values:
#   cp .env.example .env
# Then start the stack:
#   docker compose up -d --build

# Public host the stack will serve from — IPv4 address or domain name.
# Do NOT include http:// or a port. Examples: 203.0.113.10  |  oztemur.com
PUBLIC_HOST=203.0.113.10

# Password for the bundled PostgreSQL container — pick something strong.
POSTGRES_PASSWORD=change-this-strong-db-password

# JWT signing key — MUST be at least 32 characters.
JWT_SECRET=change-this-to-a-long-random-string-of-32-plus-characters
